{
  "version": 2,
  "framework": null,
  "builds": [
    {
      "src": "app.py",
      "use": "@vercel/python"
    },
    {
      "src": "static/**",
      "use": "@vercel/static"
    },
    {
      "src": "templates/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "/static/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/app.py"
    }
  ],
  "env": {
    "VERCEL": "1"
  },
  "buildCommand": null,
  "outputDirectory": null,
  "installCommand": "pip install -r requirements.txt",
  "ignoreCommand": ""
}
